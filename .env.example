# Discourse Configuration (no trailing slash)
VITE_DISCOURSE_URL=https://forum.yourcommunity.org
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=CAC Forms

# Discourse group name for verified users (Admin > Groups)
VITE_VERIFIED_GROUP_NAME=verified-members

# Discourse custom user field IDs (Admin > Customize > User Fields)
VITE_PHONE_FIELD_ID=2
VITE_EMERGENCY_CONTACT_FIELD_ID=3
VITE_BLOOD_GROUP_FIELD_ID=4
VITE_AGE_GROUP_FIELD_ID=5

# Google Sheets Configuration
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
VITE_SHEETS_SECRET=your-shared-secret-here

# Google Form for non-members signup (optional)
VITE_GOOGLE_FORM_URL=https://forms.google.com/your-form-here
